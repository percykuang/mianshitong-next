# 本地开发请使用 .env.development，生产部署请改为平台注入或复制为 .env 后填写真实值。

# development 环境：DATABASE_URL="postgresql://mianshitong_next:mianshitong_next@127.0.0.1:5434/mianshitong_next?schema=public"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# 应用运行环境（development / production）
APP_ENV=development

# ollama 本地开发模型配置
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_API_KEY=ollama
# 可选：覆盖模型目录中（packages/llm/src/environment-catalog.ts）的默认模型
# OLLAMA_MODEL=qwen3:1.7b

# DeepSeek 配置
DEEPSEEK_API_KEY="your-deepseek-api-key"
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 可选：覆盖模型目录中（packages/llm/src/environment-catalog.ts）的默认模型
# DEEPSEEK_MODEL=deepseek-v4-flash

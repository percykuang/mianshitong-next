generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AuthUser {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  role         AuthUserRole  @default(user)
  actor        UserActor?
  sessions     AuthSession[]
  chatSessions ChatSession[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model AuthSession {
  id               String   @id @default(cuid())
  sessionTokenHash String   @unique
  userId           String
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt(sort: Desc)])
  @@index([expiresAt(sort: Desc)])
}

enum ChatMessageRole {
  user
  assistant
}

enum ChatMessageFeedback {
  like
  dislike
}

enum ChatMessageCompletionStatus {
  completed
  interrupted
}

enum AuthUserRole {
  user
  admin
}

enum UserActorType {
  guest
  registered
}

model UserActor {
  id              String           @id @default(cuid())
  type            UserActorType
  displayName     String
  authUserId      String?          @unique
  guestTokenHash  String?          @unique
  dailyModelQuota Int?
  chatSessions    ChatSession[]
  chatReplyUsages ChatReplyUsage[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lastSeenAt      DateTime         @default(now())
  authUser        AuthUser?        @relation(fields: [authUserId], references: [id], onDelete: SetNull)

  @@index([type, lastSeenAt(sort: Desc)])
}

model ChatSession {
  id        String        @id @default(cuid())
  actorId   String
  userId    String?
  title     String
  preview   String        @default("")
  modelId   String
  pinned    Boolean       @default(false)
  pinnedAt  DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  actor     UserActor     @relation(fields: [actorId], references: [id], onDelete: Cascade)
  user      AuthUser?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages  ChatMessage[]

  @@index([actorId, pinned, pinnedAt(sort: Desc), updatedAt(sort: Desc)])
  @@index([actorId, updatedAt(sort: Desc)])
  @@index([userId, updatedAt(sort: Desc)])
}

model ChatMessage {
  id               String                      @id @default(cuid())
  sessionId        String
  role             ChatMessageRole
  content          String
  completionStatus ChatMessageCompletionStatus?
  feedback         ChatMessageFeedback?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  session          ChatSession                 @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt(sort: Asc)])
}

model ChatReplyUsage {
  id                 String    @id @default(cuid())
  actorId            String
  assistantMessageId String @unique
  createdAt          DateTime  @default(now())
  actor              UserActor @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId, createdAt(sort: Desc)])
}

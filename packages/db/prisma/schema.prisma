generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AuthUser {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  actor        UserActor?
  sessions     AuthSession[]
  chatSessions ChatSession[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model AdminUser {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  sessions     AdminSession[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model AdminSession {
  id               String    @id @default(cuid())
  sessionTokenHash String    @unique
  adminUserId      String
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  adminUser        AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, expiresAt(sort: Desc)])
  @@index([expiresAt(sort: Desc)])
}

model AuthSession {
  id               String   @id @default(cuid())
  sessionTokenHash String   @unique
  userId           String
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt(sort: Desc)])
  @@index([expiresAt(sort: Desc)])
}

enum ChatMessageRole {
  user
  assistant
}

enum ChatMessageFeedback {
  like
  dislike
}

enum ChatMessageCompletionStatus {
  completed
  interrupted
}

enum ChatSessionTitleSource {
  fallback
  ai
  manual
}

enum UserActorType {
  guest
  registered
}

enum ChatModelProvider {
  deepseek
  ollama
  openaiCompatible
}

model UserActor {
  id              String           @id @default(cuid())
  type            UserActorType
  displayName     String
  authUserId      String?          @unique
  guestTokenHash  String?          @unique
  dailyModelQuota Int?
  chatSessions    ChatSession[]
  chatReplyUsages ChatReplyUsage[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lastSeenAt      DateTime         @default(now())
  authUser        AuthUser?        @relation(fields: [authUserId], references: [id], onDelete: SetNull)

  @@index([type, lastSeenAt(sort: Desc)])
}

model ChatSession {
  id           String                 @id @default(cuid())
  actorId      String
  userId       String?
  title        String
  titleSource  ChatSessionTitleSource @default(fallback)
  preview      String                 @default("")
  modelId      String
  pinned       Boolean                @default(false)
  pinnedAt     DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  actor        UserActor              @relation(fields: [actorId], references: [id], onDelete: Cascade)
  user         AuthUser?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages     ChatMessage[]
  careerThread CareerThread?

  @@index([actorId, pinned, pinnedAt(sort: Desc), updatedAt(sort: Desc)])
  @@index([actorId, updatedAt(sort: Desc)])
  @@index([userId, updatedAt(sort: Desc)])
}

model CareerThread {
  id            String      @id @default(cuid())
  chatSessionId String      @unique
  state         Json
  version       Int         @default(1)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id               String                       @id @default(cuid())
  sessionId        String
  role             ChatMessageRole
  content          String
  completionStatus ChatMessageCompletionStatus?
  feedback         ChatMessageFeedback?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  session          ChatSession                  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt(sort: Asc)])
}

model ChatReplyUsage {
  id                 String    @id @default(cuid())
  actorId            String
  assistantMessageId String    @unique
  createdAt          DateTime  @default(now())
  actor              UserActor @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId, createdAt(sort: Desc)])
}

model ChatModelConfig {
  id                 String            @id
  label              String
  description        String?
  provider           ChatModelProvider
  baseUrl            String
  apiKeyCiphertext   String
  apiKeyPreview      String            @default("")
  model              String
  enabled            Boolean           @default(true)
  isDefault          Boolean           @default(false)
  sortOrder          Int               @default(0)
  supportsJsonOutput Boolean           @default(false)
  modelKwargs        Json?
  jsonModelKwargs    Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([enabled, isDefault, sortOrder, updatedAt(sort: Desc)])
}
